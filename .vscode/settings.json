{
	"deno.enable": false,
	"zig.zls.enabled": "on",
	"zig.path": "zig",
	"zig.zls.path": "zls",
	"zig.zls.semanticTokens": "full",
	"zig.zls.warnStyle": true,
	"zig.zls.highlightGlobalVarDeclarations": true,
	"zig.zls.preferAstCheckAsChildProcess": true,
	"zig.zls.skipStdReferences": false,
	"zig.zls.enableSnippets": true,
	"zig.zls.enableArgumentPlaceholders": true,
	"zig.zls.completionLabelDetails": true,
	"zig.zls.inlayHintsShowVariableTypeHints": true,
	"zig.zls.inlayHintsShowStructLiteralFieldType": true,
	"zig.zls.inlayHintsShowParameterName": true,
	"zig.zls.inlayHintsShowBuiltin": true,
	"zig.zls.inlayHintsExcludeSingleArgument": true,
	"zig.zls.inlayHintsHideRedundantParamNames": true,
	"zig.zls.inlayHintsHideRedundantParamNamesLastToken": true,
	"rust-analyzer.procMacro.enable": true,
	"rust-analyzer.server.path": "rust-analyzer",
	"rust-analyzer.diagnostics.experimental.enable": true,
	"rust-analyzer.cargo.target": "x86_64-unknown-none",
	"rust-analyzer.check.allTargets": false,
	"clangd.enable": false,
	"nix.enableLanguageServer": false,
	"ruff.enable": false,
}

# https://EditorConfig.org
root = true

[*]
indent_style = tab
indent_size = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8

[*.nix]
indent_style = space
indent_size = 2

# Rust
[*.rs]
insert_final_newline = false

# Zig
[*.zig]
indent_size = 4
indent_style = space

# yaml is the worst language in the world
[*.{yaml,yml}]
indent_style = space
indent_size = 2

[{.*,*.md,*.toml,*.yml,*.yaml}]
indent_style = space
